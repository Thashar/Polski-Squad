# ----------------------------------------------------------------
# Integracja z aplikacją webową (Polski-Squad/app)
# ----------------------------------------------------------------

# URL serwera API aplikacji webowej, np. https://api.twoja-domena.com
# (bez końcowego slash)
APP_API_URL=""

# Tajny klucz współdzielony między botem a API aplikacji.
# Musi być identyczny jak BOT_API_KEY w pliku .env aplikacji.
# Wygeneruj poleceniem: openssl rand -hex 32
BOT_API_KEY=""
